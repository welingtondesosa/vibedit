{
  "name": "@vibedit/next",
  "version": "0.2.2",
  "description": "Visual editing overlay for Next.js — edit styles live in your browser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "vibedit": "bin/vibedit.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@vibedit/server": "*"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "next": "^14.2.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "vibedit",
    "nextjs",
    "visual-editor",
    "css",
    "developer-tools"
  ],
  "license": "MIT"
}
