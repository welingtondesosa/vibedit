{
  "name": "@vibedit/vite",
  "version": "0.1.5",
  "description": "Visual editing overlay for Vite — edit styles live in your browser",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@vibedit/server": "*"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "keywords": [
    "vibedit",
    "vite",
    "visual-editor",
    "css",
    "developer-tools"
  ],
  "license": "MIT"
}
